# Tiger Voice Agent - Environment Configuration
# Copy to .env and fill in values

# ---- Mode ----
# Set to "false" to use real Vapi.ai voice agent
# Set to "true" to run without Vapi (mock mode, webhook testing only)
MOCK_MODE=true

# ---- Vapi.ai (required when MOCK_MODE=false) ----
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=

# ---- Infrastructure ----
REDIS_URL=redis://redis:6379
MOCK_BACKENDS_URL=http://mock-backends:8001

# ---- Logging ----
LOG_LEVEL=INFO

# ---- Failure Injection (mock backends) ----
# Probability of simulated failure (0.0 to 1.0)
FAILURE_RATE=0.0
# Simulated latency added to mock API responses (ms)
LATENCY_MS=0
